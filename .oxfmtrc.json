{
  "arrowParens": "avoid",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "none",
  "sortPackageJson": true,
  "sortImports": {
    "groups": ["builtin", "external", "parent", "sibling", "index"],
    "newlinesBetween": true,
    "order": "asc",
    "ignoreCase": true
  }
}
